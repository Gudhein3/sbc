extern printf
extern fprintf
extern stderr
extern atoi

fact(n)!
    if n <= 0
        1;
    else
        n*fact(n-1);

usage(prog)!
    fprintf(*stderr, "Usage: %s fibonacci-seq-limit\n", prog);

global main
main(argc, argv) max, x, y, z {
    1 : x;
    2 : y;
    if argc != 2 {
        usage(argv[0]);
        return 2;
    }
    atoi(argv[1]) : max;
    while x < max {
        printf("%d\n", x);
        y : z;
        x + y : y;
        z : x;
    }
    printf("5! = %d\n", fact(5));
    0 : x;
    while 1 {
        printf("%d\n", x);
        if x >= 3 break;
        x + 1 : x;
    }
    printf("Hexadecimal escape sequence: \x48\x61\x79\x6F!\x0A");
    printf("2<<60=0x%zx\n", 2<<60);
    printf("0x2000000000000000>>60=%zu\n", 0x2000000000000000>>60);
    printf("The compiler doesn't support operator precendence so 2+2*2 should be equal to 8. If we compute it, we'd have the same result: %zu\n", 2+2*2);
    0;
}
