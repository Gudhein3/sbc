variables[160]; /* variable[0] - frame_offset;
                   variable[1]..variable[4] - name (ascii);
                */
varcnt;

activecharacter;
stream[128];
streamsize;

inputfile;
outputfile;
dooutputparse;

TOKNUM;
TOKSTR;
TOKCHAR;
TOKID;
TOKEOF;
TOKLPAR;
TOKRPAR;
TOKEXCL;
TOKLESS;
TOKGRET;
TOKEQU;
TOKEQUEQU;
TOKSEMI;
TOKASTER;
TOKSLASH;
TOKPLUS;
TOKMINUS;
TOKLBRACK;
TOKRBRACK;
TOKCOMMA;
TOKLBRACE;
TOKRBRACE;
TOKAMPERS;
TOKVTBAR;
TOKPERS;
TOKKWIF;
TOKKWELSE;
TOKKWWHILE;
TOKKWEXTERN;
TOKKWGLOBAL;
TOKKWRETURN;
TOKEXCLEQU;
TOKLESSLESS;
